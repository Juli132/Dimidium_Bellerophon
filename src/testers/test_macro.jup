# valid test cases

# minimum macro
M.title "Minimal"
Home
M.end

#home with coords
M.title "HomeCoords"
Absolute
Home -> x=0 y=0 z=5;
M.end

#movement and directions
M.title "MovementTest"
Move left
Move right
Move center
M.end

#heating commands
M.title "HeatingTest"
Heat extruder: 200
Heat bed: 60
WaitForTemp extruder
WaitForTemp bed
M.end


# extrusions and coordList
M.title "ExtrudeTest"
MoveTo x=10 y=20 e=5;
MoveTo x=30 e=2
M.end

#conditional block
M.title "ConditionalTest"
if extruder > 150
Respond MSG "Extruder hot enough"
endif
M.end

#fan and speed
M.title "FanSpeed"
SetSpeed: 120
SetFan: 80
M.end

# bed mesh and calibration commands
M.title "Calibration"
Level
BedMeshCalibrate
ProbeCalibrate
LoadBedMesh "default"
M.end

#Extruder state commands
M.title "ExtruderState"
RelativeExtrusion
ResetExtruder
M.end

#nested macros
M.title "MacroCaller"
M.call "PreheatPLA"
Pause
M.end


#full macros
M.title "FullMacro"
Absolute
Home -> x=0 y=0 z=5;
Heat extruder: 200
Heat bed: 60
WaitForTemp extruder
SetPressureAdvance 0.04
MoveTo x=50 y=50 e=10;
Respond MSG "Ready to print"
PRINTFILE "test.gcode"
cooldown bed
TIMEOUT_SET 300
M.end

